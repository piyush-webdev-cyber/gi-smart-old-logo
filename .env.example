# --- Form submission (choose one) ---
# Option A: Formspree (no server SMTP needed – works on GoDaddy). Sign up at formspree.io, create a form, paste Form ID below and rebuild.
# NEXT_PUBLIC_FORMSPREE_FORM_ID=your_form_id_here

# Option B: Server email (submit.php or Next API) – needs SMTP or PHP mail
# Email notification when someone submits the admission form (sends to jasmeet@landmarkglobal.co.in)
# Gmail: enable 2-Step Verification, then create App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=amankk0007@gmail.com
SMTP_PASS=your-16-char-app-password

# Option 2: BigRock / cPanel email (use your domain email and password)
# SMTP_HOST=mail.yourdomain.com
# SMTP_PORT=587
# SMTP_USER=noreply@yourdomain.com
# SMTP_PASS=your-email-password

# Optional: "From" address shown in the email (defaults to SMTP_USER)
# SMTP_FROM=noreply@yourdomain.com
